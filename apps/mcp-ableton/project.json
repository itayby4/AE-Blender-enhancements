{
  "name": "@pipefx/mcp-ableton",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/mcp-ableton/src",
  "tags": ["type:app", "scope:mcp"],
  "targets": {
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": ".\\venv\\Scripts\\python.exe -m mcp_ableton.server",
        "cwd": "apps/mcp-ableton"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": ".\\venv\\Scripts\\python.exe -c \"import mcp_ableton.server; print('smoke ok')\"",
        "cwd": "apps/mcp-ableton"
      }
    }
  }
}
