{
  "name": "@pipefx/mcp-aftereffects",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/mcp-aftereffects/src",
  "tags": ["type:app", "scope:mcp"],
  "targets": {
    "serve": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "command": "node build/index.js",
        "cwd": "apps/mcp-aftereffects"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "command": "node --check build/index.js",
        "cwd": "apps/mcp-aftereffects"
      }
    }
  }
}
