# ── PipeFX Desktop Environment Variables ──

# Supabase Auth (auth-only)
# Fill these in locally. NEVER commit real values — keep this file with blanks only.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Paddle Billing (overlay checkout)
# Get these from Paddle Dashboard → Developer Tools → Authentication
VITE_PADDLE_CLIENT_TOKEN=
VITE_PADDLE_ENV=sandbox

# Paddle Price IDs (from Paddle Dashboard → Catalog → Products → each plan's price)
VITE_PADDLE_PRICE_STARTER=
VITE_PADDLE_PRICE_CREATOR=
VITE_PADDLE_PRICE_STUDIO=
