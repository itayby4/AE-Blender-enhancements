{
  "name": "@pipefx/skills",
  "version": "0.0.1",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "@pipefx/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./contracts": {
      "@pipefx/source": "./src/contracts/index.ts",
      "types": "./dist/contracts/index.d.ts",
      "import": "./dist/contracts/index.js",
      "default": "./dist/contracts/index.js"
    },
    "./domain": {
      "@pipefx/source": "./src/domain/index.ts",
      "types": "./dist/domain/index.d.ts",
      "import": "./dist/domain/index.js",
      "default": "./dist/domain/index.js"
    }
  },
  "files": [
    "dist",
    "!**/*.tsbuildinfo"
  ],
  "dependencies": {
    "@pipefx/connectors-contracts": "workspace:*",
    "@pipefx/event-bus": "workspace:*",
    "tslib": "^2.3.0",
    "zod": "^3.22.2"
  },
  "nx": {
    "tags": [
      "scope:feature",
      "feature:skills"
    ]
  }
}
