{
  "name": "@pipefx/post-production",
  "version": "0.0.1",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "@pipefx/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./contracts": {
      "@pipefx/source": "./src/contracts/index.ts",
      "types": "./dist/contracts/index.d.ts",
      "import": "./dist/contracts/index.js",
      "default": "./dist/contracts/index.js"
    },
    "./workflows": {
      "@pipefx/source": "./src/workflows/index.ts",
      "types": "./dist/workflows/index.d.ts",
      "import": "./dist/workflows/index.js",
      "default": "./dist/workflows/index.js"
    },
    "./backend": {
      "@pipefx/source": "./src/backend/index.ts",
      "types": "./dist/backend/index.d.ts",
      "import": "./dist/backend/index.js",
      "default": "./dist/backend/index.js"
    }
  },
  "files": [
    "dist",
    "!**/*.tsbuildinfo"
  ],
  "dependencies": {
    "@google/genai": "^1.46.0",
    "@pipefx/brain-memory": "workspace:*",
    "@pipefx/connectors": "workspace:*",
    "@pipefx/video-kit": "workspace:*",
    "openai": "^6.32.0",
    "tslib": "^2.3.0"
  },
  "nx": {
    "tags": [
      "scope:feature",
      "feature:post-production"
    ]
  }
}
