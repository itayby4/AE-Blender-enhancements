{
  "name": "@pipefx/chat",
  "version": "0.0.1",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "@pipefx/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./contracts": {
      "@pipefx/source": "./src/contracts/index.ts",
      "types": "./dist/contracts/index.d.ts",
      "import": "./dist/contracts/index.js",
      "default": "./dist/contracts/index.js"
    },
    "./ui": {
      "@pipefx/source": "./src/ui/index.ts",
      "types": "./dist/ui/index.d.ts",
      "import": "./dist/ui/index.js",
      "default": "./dist/ui/index.js"
    },
    "./backend": {
      "@pipefx/source": "./src/backend/index.ts",
      "types": "./dist/backend/index.d.ts",
      "import": "./dist/backend/index.js",
      "default": "./dist/backend/index.js"
    }
  },
  "files": [
    "dist",
    "!**/*.tsbuildinfo"
  ],
  "dependencies": {
    "@pipefx/agent-loop-kernel": "workspace:*",
    "@pipefx/auth": "workspace:*",
    "@pipefx/brain-contracts": "workspace:*",
    "@pipefx/connectors": "workspace:*",
    "@pipefx/llm-providers": "workspace:*",
    "@pipefx/skills": "workspace:*",
    "@pipefx/tasks": "workspace:*",
    "@pipefx/ui-kit": "workspace:*",
    "tslib": "^2.3.0"
  },
  "peerDependencies": {
    "lucide-react": "^0.575.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "peerDependenciesMeta": {
    "lucide-react": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3"
  },
  "nx": {
    "tags": [
      "scope:feature",
      "feature:chat"
    ]
  }
}
