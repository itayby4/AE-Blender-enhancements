{
  "name": "@pipefx/connectors",
  "version": "0.0.1",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "@pipefx/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./backend": {
      "@pipefx/source": "./src/backend.ts",
      "types": "./dist/backend.d.ts",
      "import": "./dist/backend.js",
      "default": "./dist/backend.js"
    },
    "./ui": {
      "@pipefx/source": "./src/ui.ts",
      "types": "./dist/ui.d.ts",
      "import": "./dist/ui.js",
      "default": "./dist/ui.js"
    }
  },
  "files": [
    "dist",
    "!**/*.tsbuildinfo"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@pipefx/connectors-contracts": "workspace:*",
    "@pipefx/event-bus": "workspace:*",
    "@pipefx/mcp-transport": "workspace:*",
    "clsx": "^2.1.1",
    "lucide-react": "^0.575.0",
    "tailwind-merge": "^3.5.0",
    "tslib": "^2.3.0"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3"
  },
  "nx": {
    "tags": [
      "scope:feature",
      "feature:connectors"
    ]
  }
