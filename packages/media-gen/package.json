{
  "name": "@pipefx/media-gen",
  "version": "0.0.1",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "@pipefx/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./contracts": {
      "@pipefx/source": "./src/contracts/index.ts",
      "types": "./dist/contracts/index.d.ts",
      "import": "./dist/contracts/index.js",
      "default": "./dist/contracts/index.js"
    },
    "./backend": {
      "@pipefx/source": "./src/backend/index.ts",
      "types": "./dist/backend/index.d.ts",
      "import": "./dist/backend/index.js",
      "default": "./dist/backend/index.js"
    },
    "./jobs": {
      "@pipefx/source": "./src/jobs/index.ts",
      "types": "./dist/jobs/index.d.ts",
      "import": "./dist/jobs/index.js",
      "default": "./dist/jobs/index.js"
    }
  },
  "files": [
    "dist",
    "!**/*.tsbuildinfo"
  ],
  "dependencies": {
    "tslib": "^2.3.0",
    "@pipefx/media-providers": "workspace:*"
  },
  "nx": {
    "tags": [
      "scope:feature",
      "feature:media-gen"
    ]
  }
}
